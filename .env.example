# NER Platform — Environment Configuration
# Copy this file to .env and adjust values for your local setup.
# All variables use the NER_ prefix. Settings are loaded by pydantic-settings.

# --- Database ---
NER_DATABASE_URL=postgresql+asyncpg://ner:ner@localhost:5432/ner_dev
NER_DATABASE_URL_SYNC=postgresql://ner:ner@localhost:5432/ner_dev

# --- Redis (JWT blacklist, caching) ---
NER_REDIS_URL=redis://localhost:6379/0

# --- JWT ---
# REQUIRED — generate with: openssl rand -hex 32
NER_JWT_SECRET=
NER_JWT_ALGORITHM=HS256

# --- JWT Token Lifetimes ---
NER_ACCESS_TOKEN_TTL_MINUTES=15
NER_REFRESH_TOKEN_TTL_DAYS=7

# --- MinIO / S3-compatible Object Storage ---
NER_MINIO_ENDPOINT=localhost:9000
# REQUIRED — must match MINIO_ROOT_USER below
NER_MINIO_ACCESS_KEY=
# REQUIRED — must match MINIO_ROOT_PASSWORD below
NER_MINIO_SECRET_KEY=
NER_MINIO_BUCKET=ner-platform

# --- MLflow Tracking ---
NER_MLFLOW_TRACKING_URI=http://localhost:5000

# --- Inter-service URLs ---
# Default values are for bare-metal runs (services started manually with uvicorn).
# docker-compose.yml overrides these to Docker service names (http://<service>:8000)
# when running the full stack via `docker compose up`.
NER_DOCUMENT_SERVICE_URL=http://localhost:8001
NER_MODEL_SERVING_URL=http://localhost:8004

# --- Model Serving ---
NER_MODEL_SERVING_PORT=8004
NER_MODEL_CACHE_MEMORY_LIMIT_GB=2
NER_MODEL_CACHE_TTL_MINUTES=30

# --- Extraction Service ---
NER_EXTRACTION_CELERY_QUEUE=extraction
NER_CONFIDENCE_THRESHOLD=0.50

# --- docker-compose service credentials ---
# These are consumed directly by docker-compose (not NER_-prefixed).
# They must be set here so docker-compose can resolve them via ${VAR} interpolation.
# REQUIRED — MinIO admin username (match NER_MINIO_ACCESS_KEY above)
MINIO_ROOT_USER=
# REQUIRED — MinIO admin password (match NER_MINIO_SECRET_KEY above)
MINIO_ROOT_PASSWORD=
# REQUIRED — MLflow uses these to access MinIO as S3; set equal to MINIO_ROOT_USER/PASSWORD
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
